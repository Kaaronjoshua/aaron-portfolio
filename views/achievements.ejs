<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Aaron Kambhampati's achievements — AWS certifications, hackathon wins, and mentoring 200+ students in Data Science and AI.">
  <title>Achievements — Aaron Kambhampati</title>
  <link rel="icon" type="image/x-icon" href="/images/favicon_io/favicon.ico">
  <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon_io/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/images/favicon_io/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/images/favicon_io/apple-touch-icon.png">

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" crossorigin="anonymous"/>
  <link rel="stylesheet" href="/styles/styles.css">
</head>
<body>

  <%- include("partials/header", { page: "achievements" }) %>

  <main class="page-content achievements-page">

    <!-- ============================================================
         HERO — dark chapter opener
    ============================================================ -->
    <section class="ach-hero">
      <div class="ach-hero-inner">
        <span class="ach-label reveal">Recognition</span>
        <h1 class="ach-title reveal">Achieve<br>ments.</h1>
        <p class="ach-subtitle reveal">
          Certifications earned, competitions won,<br>
          and students set in motion.
        </p>
      </div>
      <div class="ach-hero-count reveal-right">
        <span>07</span>
        <p>highlights</p>
      </div>
    </section>


    <!-- ============================================================
         CERTIFICATIONS — 5 cards
    ============================================================ -->
    <section class="certs-section">

      <div class="certs-header">
        <div class="reveal">
          <span class="section-eyebrow">Credentials</span>
          <h2 class="certs-title">Certifications</h2>
        </div>
        <span class="certs-tally reveal">05 / 05</span>
      </div>

      <div class="certs-grid">

        <div class="cert-card reveal" style="--accent: #4285f4;">
          <span class="cert-num">01</span>
          <div class="cert-body">
            <h3 class="cert-name">AWS Machine Learning Enghineer Associate</h3>
            <p class="cert-issuer">Amazon.AI</p>
            <p class="cert-year">2026</p>
          </div>
          <div class="cert-bar"></div>
        </div>

        <div class="cert-card reveal" style="--accent: #e63946;">
          <span class="cert-num">02</span>
          <div class="cert-body">
            <h3 class="cert-name">Azure AI-900</h3>
            <p class="cert-issuer">Azure / Microsoft</p>
            <p class="cert-year">2024</p>
          </div>
          <div class="cert-bar"></div>
        </div>

        <div class="cert-card reveal" style="--accent: #ff9900;">
          <span class="cert-num">03</span>
          <div class="cert-body">
            <h3 class="cert-name">Data Science Professional</h3>
            <p class="cert-issuer">Oracle</p>
            <p class="cert-year">2023</p>
          </div>
          <div class="cert-bar"></div>
        </div>

        <div class="cert-card reveal" style="--accent: #34a853;">
          <span class="cert-num">04</span>
          <div class="cert-body">
            <h3 class="cert-name">Data Analyst Associate</h3>
            <p class="cert-issuer">PL-300 / Microsoft</p>
            <p class="cert-year">2023</p>
          </div>
          <div class="cert-bar"></div>
        </div>

        <div class="cert-card reveal" style="--accent: #7b2d8b;">
          <span class="cert-num">05</span>
          <div class="cert-body">
            <h3 class="cert-name">Deep Learning</h3>
            <p class="cert-issuer">DeepLearning.AI / IBM</p>
            <p class="cert-year">2023</p>
          </div>
          <div class="cert-bar"></div>
        </div>

      </div>
    </section>


    <!-- ============================================================
         HACKATHON WIN — dramatic dark section
    ============================================================ -->
    <section class="hackathon-section">

      <div class="hack-bg-word">WINNER</div>

      <div class="hack-inner">

        <div class="hack-left reveal-left">
          <span class="hack-eyebrow">Competition</span>
          <div class="hack-trophy-wrap">
            <i class="fa-solid fa-trophy"></i>
          </div>
          <p class="hack-place">1<sup>st</sup> Place</p>
          <p class="hack-year-badge">2024</p>
        </div>

        <div class="hack-divider"></div>

        <div class="hack-right reveal-right">
          <h2 class="hack-title">Hackathon<br>Winner.</h2>
          <p class="hack-event">AWS AI JAM Hackathon 2024</p>
          <p class="hack-desc">
            Recognized for pioneering Directional LLMs, a novel AI framework that guides Large Language 
            Models using structured reasoning signals and contextual intelligence. The directional 
            guidance can range from a simple classification label to multi-threshold categorical 
            signals generated by machine learning models, enabling the LLM to reason within a targeted
             decision space rather than relying solely on generic prompting. The solution demonstrated 
             significant improvements in healthcare decision-support workflows and was awarded for its 
             innovation, research contribution, and real-world applicability in high-stakes AI systems.
          </p>
          <div class="hack-tags">
            <span>AWS</span>
            <span>Directional LLM's</span>
            <span>Accessibility Tech</span>
            <span>Life Insurance</span>
          </div>
        </div>

      </div>
    </section>


    <!-- ============================================================
         MENTORING — large stat + description
    ============================================================ -->
    <section class="mentoring-section">

      <div class="mentor-left reveal-left">
        <div class="mentor-stat-wrap">
          <span class="mentor-stat" data-target="50">0</span>
          <span class="mentor-plus">+</span>
        </div>
        <p class="mentor-stat-label">students</p>
      </div>

      <div class="mentor-right reveal-right">
        <span class="section-eyebrow">Impact</span>
        <h2 class="mentor-title">Mentored &<br>Tutored.</h2>
        <p class="mentor-desc">
          Guided 50+ students through the realities of Data Science, Python programming,
          and machine learning — as a peer mentor, lab assistant, and 1-on-1 tutor.
          Helped students go from zero to submitting their first models.
        </p>
        <div class="mentor-points">
          <div class="mentor-point">
            <i class="fa-solid fa-users"></i>
            <span>University peer mentor program</span>
          </div>
          <div class="mentor-point">
            <i class="fa-solid fa-laptop-code"></i>
            <span>Python, ML & AI fundamentals</span>
          </div>
          <div class="mentor-point">
            <i class="fa-solid fa-chalkboard-user"></i>
            <span>1-on-1 sessions & group workshops</span>
          </div>
        </div>
      </div>

    </section>

  </main>

  <%- include("partials/footer") %>
  <script src="/JS/main.js"></script>
</body>
</html>
