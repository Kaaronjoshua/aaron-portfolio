  <!-- Join Now modal -->
  <div class="mm-overlay" id="mmOverlay">
    <div class="mm-modal">
      <button class="mm-modal-close" id="mmModalClose">✕</button>

      <div id="mmFormWrap">
        <h3 class="mm-modal-title">Join Minds & Machines</h3>
        <p class="mm-modal-sub">Tell us about yourself and we'll be in touch.</p>

        <form id="mmForm">
          <div class="mm-field">
            <label for="mmName">Full Name</label>
            <input type="text" id="mmName" placeholder="Your name" required>
          </div>
          <div class="mm-field">
            <label for="mmEmail">Email</label>
            <input type="email" id="mmEmail" placeholder="you@email.com" required>
          </div>
          <div class="mm-field">
            <label for="mmProfession">Profession</label>
            <input type="text" id="mmProfession" placeholder="e.g. Student, Engineer, Researcher" required>
          </div>
          <button type="submit" class="mm-submit">Submit →</button>
