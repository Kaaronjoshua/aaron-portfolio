    </div>
  </div>

  <%- include("partials/footer") %>

  <script src="/JS/main.js"></script>
  <script>
    /* ── DATA ── */
    const CITIES = [
      {
        id:        "noida",
        name:      "Noida, India",
        coords:    [77.391, 28.535],
        company:   "LUMIQ.AI",
        role:      "Data Scientist",
        period:    "Aug 2023 – Present",
        desc:      "Building ML pipelines, analytics solutions, and data-driven products for enterprise clients across India.",
        research:  false,
        startYear: 2023
      },
      {
        id:        "sf",
        name:      "San Francisco, USA",
        coords:    [-122.419, 37.773],
        company:   "Supply Chain for Semi-Conductors",
        role:      "Research — Global Operations",
        period:    "2025 – Present",
        desc:      "Designing intelligent supply chain systems for the semiconductor industry with cross-border logistics intelligence.",
        research:  true,
        startYear: 2025
      },
      {
        id:        "pune",
        name:      "Pune, India",
        coords:    [73.856, 18.520],
        company:   "LUMIQ.AI",
        role:      "Data Scientist",
        period:    "Aug 2023 – Present",
        desc:      "End-to-end data science projects — from raw data ingestion to production-ready model deployment.",
        research:  false,
        startYear: 2026
      },
      {
        id:        "singapore",
        name:      "Singapore",
        coords:    [103.820, 1.352],
        company:   "Supply Chain for Semi-Conductors",
        role:      "Research — APAC Operations",
        period:    "2025 – Present",
        desc:      "Mapping semiconductor supply flows across Southeast Asia with data-driven demand forecasting models.",
        research:  true,
        startYear: 2026
      }
    ];

    /* ── TIMELINE STATE ── */
    const CURRENT_YEAR = new Date().getFullYear();
    let selectedYear   = CURRENT_YEAR;

    /* ── SLIDER SETUP ── */
    function initSlider() {
      const slider   = document.getElementById("yearSlider");
      const labelsEl = document.getElementById("yearLabels");

      slider.max   = CURRENT_YEAR;
      slider.value = CURRENT_YEAR;

      // Build year tick labels
      for (let y = 2023; y <= CURRENT_YEAR; y++) {
        const span = document.createElement("span");
        span.className = "year-tick" + (y === CURRENT_YEAR ? " active" : "");
        span.dataset.year = y;
        span.textContent  = y;
        labelsEl.appendChild(span);
      }

      setSliderFill(slider);

      slider.addEventListener("input", () => {
        selectedYear = +slider.value;
        setSliderFill(slider);
        highlightTick(selectedYear);
        applyVisibility();
        // Dismiss card if its city is now hidden
        const activeCity = d3.select(".beacon-g.selected");
        if (!activeCity.empty()) {
          const id   = activeCity.attr("data-id");
          const city = CITIES.find(c => c.id === id);
          if (city && selectedYear < city.startYear) closeCard();
        }
      });
    }

    function setSliderFill(slider) {
      const pct = ((+slider.value - 2023) / (CURRENT_YEAR - 2023)) * 100;
      slider.style.background =
        `linear-gradient(to right, rgba(255,255,255,0.75) ${pct}%, rgba(255,255,255,0.12) ${pct}%)`;
    }

    function highlightTick(year) {
      document.querySelectorAll(".year-tick").forEach(t => {
        t.classList.toggle("active", +t.dataset.year === year);
      });
    }

    /* ── BEACON VISIBILITY ── */
    function applyVisibility() {
      CITIES.forEach(city => {
        const visible = selectedYear >= city.startYear;
        d3.select(`#world-map .beacon-g[data-id="${city.id}"]`)
          .classed("hidden", !visible);
      });
    }

    /* ── MAP ── */
    async function buildMap() {
      const svg  = d3.select("#world-map");
      const wrap = document.querySelector(".exp-map-wrap");
      const W    = wrap.clientWidth;
      const H    = wrap.clientHeight;

      svg.attr("width", W).attr("height", H);

      const projection = d3.geoNaturalEarth1()
        .fitExtent([[24, 16], [W - 24, H - 16]], { type: "Sphere" });

      const pathGen = d3.geoPath().projection(projection);

      svg.append("path")
        .datum({ type: "Sphere" })
        .attr("class", "sphere-bg")
        .attr("d", pathGen);

      svg.append("path")
        .datum(d3.geoGraticule()())
        .attr("class", "graticule")
        .attr("d", pathGen);

      const world     = await d3.json("https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json");
      const countries = topojson.feature(world, world.objects.countries);

      svg.selectAll(".country")
        .data(countries.features)
        .join("path")
        .attr("class", "country")
        .attr("d", pathGen);

      svg.append("path")
        .datum({ type: "Sphere" })
        .attr("class", "sphere-border")
        .attr("d", pathGen);

      // Beacons
      CITIES.forEach(city => {
        const [px, py] = projection(city.coords);

        const g = svg.append("g")
          .attr("class", "beacon-g" + (selectedYear < city.startYear ? " hidden" : ""))
          .attr("transform", `translate(${px},${py})`)
          .attr("data-id", city.id)
          .on("click", () => {
            if (selectedYear >= city.startYear) openCard(city);
          });

        g.append("circle").attr("class", "beacon-ring").attr("cx", 0).attr("cy", 0).attr("r", 5);
        g.append("circle").attr("class", "beacon-ring beacon-ring-b").attr("cx", 0).attr("cy", 0).attr("r", 5);
        g.append("circle").attr("class", "beacon-dot").attr("cx", 0).attr("cy", 0).attr("r", 3.5);
        g.append("text").attr("class", "beacon-label").attr("x", 0).attr("y", 22).text(city.name);
      });
    }

    /* ── INFO CARD ── */
    function openCard(city) {
      document.getElementById("cardCity").textContent    = city.name;
      document.getElementById("cardCompany").textContent = city.company;
      document.getElementById("cardRole").textContent    = city.role;
      document.getElementById("cardDesc").textContent    = city.desc || "";
      document.getElementById("cardPeriod").textContent  = city.period;
      document.getElementById("cardTag").classList.toggle("visible", city.research);
      document.getElementById("expCard").classList.add("show");

      d3.selectAll(".beacon-g").classed("selected", false);
      d3.select(`#world-map .beacon-g[data-id="${city.id}"]`).classed("selected", true);
    }

    function closeCard() {
      document.getElementById("expCard").classList.remove("show");
      d3.selectAll(".beacon-g").classed("selected", false);
    }

    document.getElementById("expCardClose").addEventListener("click", closeCard);
    document.getElementById("world-map").addEventListener("click", e => {
      if (!e.target.closest(".beacon-g")) closeCard();
    });

    /* ── SCREEN 1 HEIGHT ── */
    function fitScreen1() {
      const pc = document.querySelector(".page-content");
      const s1 = document.getElementById("expScreen1");
      if (pc && s1) s1.style.height = pc.clientHeight + "px";
    }
    fitScreen1();

    /* ── JOIN MODAL ── */
    const overlay     = document.getElementById("mmOverlay");
    const formWrap    = document.getElementById("mmFormWrap");
    const successEl   = document.getElementById("mmSuccess");

    document.getElementById("mmJoinBtn").addEventListener("click", () => {
      formWrap.style.display   = "block";
      successEl.style.display  = "none";
      document.getElementById("mmForm").reset();
      overlay.classList.add("show");
    });

    function closeModal() { overlay.classList.remove("show"); }

    document.getElementById("mmModalClose").addEventListener("click", closeModal);
    overlay.addEventListener("click", e => { if (e.target === overlay) closeModal(); });
    document.addEventListener("keydown", e => { if (e.key === "Escape") closeModal(); });

    document.getElementById("mmForm").addEventListener("submit", async e => {
      e.preventDefault();
      const btn = e.target.querySelector(".mm-submit");
      btn.disabled = true;
      btn.textContent = "Submitting…";

      try {
        const res = await fetch("/api/join", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({
            name:       document.getElementById("mmName").value.trim(),
            email:      document.getElementById("mmEmail").value.trim(),
            profession: document.getElementById("mmProfession").value.trim()
          })
        });
        const json = await res.json();
        if (json.success) {
          formWrap.style.display  = "none";
          successEl.style.display = "block";
          setTimeout(closeModal, 2800);
        } else {
          alert("Something went wrong. Please try again.");
          btn.disabled = false;
          btn.textContent = "Submit →";
        }
      } catch {
        alert("Network error. Please try again.");
        btn.disabled = false;
        btn.textContent = "Submit →";
      }
    });

    /* ── ROADMAP CAROUSEL ── */
    (function () {
      const viewport = document.getElementById('rmViewport');
      const track    = document.getElementById('rmTrack');
      const prevBtn  = document.getElementById('rmPrev');
      const nextBtn  = document.getElementById('rmNext');
      const dots     = document.querySelectorAll('.rm-progress-dot');
      const cards    = track.querySelectorAll('.rm-card');

      const CARD_W  = () => (cards[0] ? cards[0].offsetWidth + 14 : 254);
      const MAX_IDX = () => Math.max(0, cards.length - Math.floor(viewport.offsetWidth / CARD_W()));

      let idx = 0;

      function go(newIdx) {
        idx = Math.max(0, Math.min(MAX_IDX(), newIdx));
        track.style.transform = `translateX(-${idx * CARD_W()}px)`;
        prevBtn.disabled = idx === 0;
        nextBtn.disabled = idx >= MAX_IDX();
        dots.forEach((d, i) => d.classList.toggle('active', i === idx));
      }

      prevBtn.addEventListener('click', () => go(idx - 1));
      nextBtn.addEventListener('click', () => go(idx + 1));

      /* mouse drag */
      let dragging = false, startX = 0, startIdx = 0;

      viewport.addEventListener('mousedown', e => {
        dragging = true; startX = e.clientX; startIdx = idx;
        viewport.classList.add('is-dragging');
        track.style.transition = 'none';
      });
      window.addEventListener('mousemove', e => {
        if (!dragging) return;
        const delta = startX - e.clientX;
        track.style.transform = `translateX(-${Math.max(0, startIdx * CARD_W() + delta)}px)`;
      });
      window.addEventListener('mouseup', e => {
        if (!dragging) return;
        dragging = false;
        viewport.classList.remove('is-dragging');
        track.style.transition = 'transform 0.45s cubic-bezier(0.25,0.46,0.45,0.94)';
        go(startIdx + Math.round((startX - e.clientX) / CARD_W()));
      });

      /* touch */
      viewport.addEventListener('touchstart', e => {
        startX = e.touches[0].clientX; startIdx = idx;
        track.style.transition = 'none';
      }, { passive: true });
      viewport.addEventListener('touchmove', e => {
        const delta = startX - e.touches[0].clientX;
        track.style.transform = `translateX(-${Math.max(0, startIdx * CARD_W() + delta)}px)`;
      }, { passive: true });
      viewport.addEventListener('touchend', e => {
        track.style.transition = 'transform 0.45s cubic-bezier(0.25,0.46,0.45,0.94)';
        go(startIdx + Math.round((startX - e.changedTouches[0].clientX) / CARD_W()));
      });

      go(0);
    })();

    /* ── INIT ── */
    initSlider();
    buildMap();

    let resizeTimer;
    window.addEventListener("resize", () => {
      fitScreen1();
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        d3.select("#world-map").selectAll("*").remove();
        buildMap();
      }, 200);
    });
  </script>
</body>
